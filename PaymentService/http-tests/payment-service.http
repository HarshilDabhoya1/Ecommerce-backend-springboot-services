### ─────────────────────────────────────────────────────────────────────────
### PAYMENT SERVICE  —  {{payment_service}}
### Credentials are stored in http-client.private.env.json (git-ignored).
### Requests 0a–0f set up login + product + order automatically.
###
### ⚠️  Payment tests (1–5) require a real Stripe test API key.
###    Set STRIPE_SECRET_KEY=sk_test_... in PaymentService's run configuration.
###    Stripe test payment method IDs:
###      pm_card_visa                            → always succeeds
###      pm_card_mastercard                      → always succeeds
###      pm_card_chargeDeclined                  → card_declined
###      pm_card_chargeDeclinedInsufficientFunds → insufficient_funds
###      pm_card_chargeDeclinedExpiredCard       → expired_card
### ─────────────────────────────────────────────────────────────────────────

### ── SETUP ────────────────────────────────────────────────────────────────

### 0a. Create admin user (409 = already exists, which is fine)
POST {{user_service}}/users/admin/signup
Content-Type: application/json
X-Admin-Secret: {{admin_secret}}

{
  "name": "{{test_admin_name}}",
  "email": "{{test_admin_email}}",
  "password": "{{test_admin_password}}"
}

> {%
  client.test("Admin signup returns 201 or 409", function() {
    client.assert(response.status === 201 || response.status === 409,
      "Admin signup failed — check admin_secret. Got: " + response.status);
  });
%}

###

### 0b. Login as admin user — captures auth_token and user_id
POST {{user_service}}/users/login
Content-Type: application/json

{
  "email": "{{test_admin_email}}",
  "password": "{{test_admin_password}}"
}

> {%
  client.test("Admin login returns 200", function() {
    client.assert(response.status === 200, "Admin login failed — check test_admin_email/password in http-client.private.env.json");
  });
  if (response.status === 200) {
    const token = response.headers.valueOf("AUTH_TOKEN");
    client.global.set("auth_token", token);
    client.log("auth_token captured: " + token);
    if (response.body !== null) {
      client.global.set("user_id", response.body.id);
      client.log("user_id captured: " + response.body.id);
    }
  }
%}

###

### 0c. Create category (409 = already exists, both are fine)
POST {{product_service}}/categories
Content-Type: application/json
AUTH_TOKEN: {{auth_token}}
X-User-Role: ADMIN

{
  "name": "Electronics"
}

> {%
  client.test("Create category returns 201 or 409", function() {
    client.assert(response.status === 201 || response.status === 409,
      "Expected 201 or 409, got " + response.status);
  });
  if (response.status === 201 && response.body !== null) {
    client.global.set("category_id", response.body.id);
    client.log("category_id captured from create: " + response.body.id);
  }
%}

###

### 0d. Fetch all categories to capture category_id (handles the 409 case from 0c)
GET {{product_service}}/categories
AUTH_TOKEN: {{auth_token}}

> {%
  // Always capture from the list — covers both 201 (fresh create) and 409 (already exists).
  if (response.status === 200 && response.body !== null && Array.isArray(response.body)) {
    const electronics = response.body.find(function(c) { return c.name === "Electronics"; });
    if (electronics) {
      client.global.set("category_id", electronics.id);
      client.log("category_id captured from list: " + electronics.id);
    }
  }
%}

###

