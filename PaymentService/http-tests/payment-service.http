###

### 7. Get payment by ID
GET {{payment_service}}/payments/{{payment_id}}
AUTH_TOKEN: {{auth_token}}

> {%
  client.test("Get payment returns 200", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  if (response.status === 200 && response.body !== null) {
    client.test("Payment ID matches", function() {
      client.assert(response.body.id == client.global.get("payment_id"),
        "Payment ID mismatch: expected " + client.global.get("payment_id") + " got " + response.body.id);
    });
    client.test("Payment status is SUCCESS", function() {
      client.assert(response.body.status === "SUCCESS",
        "Expected SUCCESS for the successful Visa payment, got " + response.body.status);
    });
    client.test("Payment amount is correct", function() {
      client.assert(response.body.amount === 159900.00,
        "Expected amount 159900.00, got " + response.body.amount);
    });
    client.test("Payment currency is correct", function() {
      client.assert(response.body.currency === "INR",
        "Expected currency INR, got " + response.body.currency);
    });
    client.test("Transaction ID matches captured value", function() {
      client.assert(response.body.transactionId === client.global.get("transaction_id"),
        "transactionId should match what was returned at creation");
    });
  }
%}

