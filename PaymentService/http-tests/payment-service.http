### 8. Get payment — non-existent ID should return 404
GET {{payment_service}}/payments/999999
AUTH_TOKEN: {{auth_token}}

> {%
  client.test("Non-existent payment returns 404", function() {
    client.assert(response.status === 404, "Expected 404, got " + response.status);
  });
%}

###

### 9. Get all payments for an order
GET {{payment_service}}/payments/order/{{order_id}}
AUTH_TOKEN: {{auth_token}}

> {%
  client.test("Get payments by order returns 200", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  if (response.status === 200 && response.body !== null) {
    client.test("At least one payment for this order", function() {
      client.assert(Array.isArray(response.body) && response.body.length > 0,
        "Expected at least 1 payment record for order " + client.global.get("order_id"));
    });
    if (Array.isArray(response.body) && response.body.length > 0) {
      client.test("All payments belong to this order", function() {
        const oid = client.global.get("order_id");
        response.body.forEach(function(p) {
          client.assert(p.orderId == oid,
            "Payment " + p.id + " belongs to orderId " + p.orderId + " not " + oid);
        });
      });
    }
  }
%}

###

### 10. Get payment history for a user (paginated)
GET {{payment_service}}/payments/user/{{user_id}}?page=0&size=10
AUTH_TOKEN: {{auth_token}}

> {%
  client.test("User payment history returns 200", function() {
    client.assert(response.status === 200, "Expected 200, got " + response.status);
  });
  if (response.status === 200 && response.body !== null) {
    client.test("Response has pagination structure", function() {
      client.assert(Array.isArray(response.body.content), "content should be an array");
      client.assert(typeof response.body.totalElements === "number", "totalElements should be a number");
      client.assert(typeof response.body.totalPages === "number", "totalPages should be a number");
    });
    client.test("At least one payment in user history", function() {
      client.assert(response.body.content.length > 0,
        "Expected at least one payment in history for user " + client.global.get("user_id"));
    });
    if (response.body.content.length > 0) {
      client.test("Each payment record has required fields", function() {
        const p = response.body.content[0];
        client.assert(typeof p.id === "number", "payment.id should be a number");
        client.assert(typeof p.status === "string" && p.status.length > 0,
          "payment.status should be a non-empty string");
        client.assert(typeof p.amount === "number" && p.amount > 0,
          "payment.amount should be a positive number");
      });
    }
  }
%}
