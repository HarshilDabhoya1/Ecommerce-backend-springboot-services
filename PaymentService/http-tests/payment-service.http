### 4. Initiate payment — omit stripePaymentMethodId (defaults to pm_card_visa)
POST {{payment_service}}/payments
Content-Type: application/json
AUTH_TOKEN: {{auth_token}}

{
  "orderId": {{order_id}},
  "userId": {{user_id}},
  "userEmail": "{{test_admin_email}}",
  "amount": 499.00,
  "currency": "INR",
  "paymentMethod": "WALLET"
}

> {%
  client.test("Default payment method succeeds with 201", function() {
    client.assert(response.status === 201, "Expected 201 with default pm_card_visa");
  });
  if (response.status === 201 && response.body !== null) {
    client.test("Default payment status is SUCCESS", function() {
      client.assert(response.body.status === "SUCCESS",
        "Expected SUCCESS with default Visa card, got " + response.body.status);
    });
    client.test("Default payment has a transaction id", function() {
      client.assert(response.body.transactionId !== null && response.body.transactionId !== undefined,
        "transactionId should be set on successful default payment");
    });
  }
%}

