%}

###

### ── PAYMENTS ──────────────────────────────────────────────────────────────

### 1. Initiate a successful payment (Visa — always succeeds in test mode)
POST {{payment_service}}/payments
Content-Type: application/json
AUTH_TOKEN: {{auth_token}}

{
  "orderId": {{order_id}},
  "userId": {{user_id}},
  "userEmail": "{{test_admin_email}}",
  "amount": 159900.00,
  "currency": "INR",
  "paymentMethod": "CREDIT_CARD",
  "stripePaymentMethodId": "pm_card_visa"
}

> {%
  client.test("Successful payment returns 201", function() {
    client.assert(response.status === 201, "Expected 201, got " + response.status);
  });
  if (response.status === 201 && response.body !== null) {
    client.test("Payment has a valid id", function() {
      client.assert(typeof response.body.id === "number", "id should be a number");
    });
    client.test("Payment status is SUCCESS", function() {
      client.assert(response.body.status === "SUCCESS",
        "Expected SUCCESS, got " + response.body.status);
    });
    client.test("Transaction ID is set on success", function() {
      client.assert(response.body.transactionId !== null && response.body.transactionId !== undefined
        && response.body.transactionId.length > 0,
        "transactionId should be a non-empty string on successful payment");
    });
    client.test("Amount matches request", function() {
      client.assert(response.body.amount === 159900.00,
        "Expected amount 159900.00, got " + response.body.amount);
    });
    client.test("Currency matches request", function() {
      client.assert(response.body.currency === "INR",
        "Expected currency INR, got " + response.body.currency);
    });
    client.test("orderId matches request", function() {
      client.assert(response.body.orderId == client.global.get("order_id"),
        "orderId in response should match the order we paid for");
    });
    client.global.set("payment_id", response.body.id);
    client.global.set("transaction_id", response.body.transactionId);
    client.log("Captured payment_id: " + response.body.id);
    client.log("Stripe transaction: " + response.body.transactionId);
  }
%}

###

### 2. Initiate a declined payment (card_declined)
POST {{payment_service}}/payments
Content-Type: application/json
AUTH_TOKEN: {{auth_token}}

{
  "orderId": {{order_id}},
  "userId": {{user_id}},
  "userEmail": "{{test_admin_email}}",
  "amount": 999.00,
  "currency": "INR",
  "paymentMethod": "DEBIT_CARD",
  "stripePaymentMethodId": "pm_card_chargeDeclined"
}

> {%
  client.test("Declined card returns 402", function() {
    client.assert(response.status === 402, "Expected 402 Payment Required, got " + response.status);
  });
  if (response.status === 402 && response.body !== null) {
    client.test("Payment status is FAILED", function() {
      client.assert(response.body.status === "FAILED",
        "Expected FAILED, got " + response.body.status);
    });
    client.test("Failure reason is set", function() {
      client.assert(response.body.failureReason !== null && response.body.failureReason !== undefined
        && response.body.failureReason.length > 0,
        "failureReason should be populated for a declined payment");
    });
    client.test("Transaction ID is null on failed payment", function() {
      client.assert(response.body.transactionId === null || response.body.transactionId === undefined,
        "transactionId should not be set when payment is declined");
    });
  }
%}

